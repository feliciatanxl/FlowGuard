# Backend (Node/Express) environment variables — placeholders only, never commit real values.

# --- Server ---
APP_PORT=3000
APP_SECRET=your-jwt-signing-secret
CLIENT_URL=http://localhost:5173            # used for CORS
FRONTEND_URL=http://localhost:5173          # base URL used in WhatsApp driver-pass links

# --- PostgreSQL (Neon / Supabase / Render) ---
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PWD=your-db-password

# --- Python AI services ---
# FACE_AI_URL is the BASE url of the InsightFace service (ai-service/main.py).
# The backend appends paths to it: /api/encode-faces, /refresh, /user/recognize.
# Do NOT put a full endpoint path here.
FACE_AI_URL=http://127.0.0.1:8501
# PYTHON_AI_URL is a FULL endpoint url used by the (teammate-owned) incident scan route.
# It already includes /recognize — do not append another path.
PYTHON_AI_URL=http://127.0.0.1:8000/recognize

# --- Google reCAPTCHA (server-side secret) ---
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# --- WhatsApp / driver notifications (Smart Logistics) ---
# Leave WHATSAPP_ENABLED=false for local/demo: the service then simulates sends and
# never calls the real API. Set it to "true" ONLY with real credentials to send live.
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here   # preferred bearer token — never commit the real value
WHATSAPP_API_KEY=your_whatsapp_access_token_here        # fallback token (used if ACCESS_TOKEN is unset)
WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_number_id_here
