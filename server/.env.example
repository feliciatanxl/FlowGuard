# Backend (Node/Express) environment variables — placeholders only, never commit real values.

# --- Server ---
APP_PORT=3000
APP_SECRET=your-jwt-signing-secret
CLIENT_URL=http://localhost:5173            # used for CORS

# --- PostgreSQL (Neon / Supabase / Render) ---
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PWD=your-db-password

# --- Python AI service ---
PYTHON_AI_URL=http://127.0.0.1:8500

# --- Google reCAPTCHA (server-side secret) ---
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# --- WhatsApp / driver notifications (optional) ---
WHATSAPP_ACCESS_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-id
