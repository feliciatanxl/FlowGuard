# Frontend (Vite) environment variables — placeholders only, never commit real values.
# All client-side vars MUST be prefixed with VITE_ to be exposed to the browser.

# Google reCAPTCHA site key (public key, used on register/login forms)
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Backend API base URL (used in production builds; local dev uses the Vite proxy)
VITE_API_URL=https://your-backend.onrender.com
